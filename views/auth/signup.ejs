<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Signup</title>

  <link rel="stylesheet" href="/css/signup.css" />
  <link rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
</head>

<body>
  <div class="container">

    <div class="logo">
      <i class="fa-solid fa-house-user"></i>
    </div>

    <h2>Create Your Account</h2>

    <form action="/signup" method="POST">

      <% if ( errors.length > 0) { %>
      <div class="error-alert">
        <div class="error-header">
          <i class="fas fa-exclamation-circle"></i>
          Please fix the following errors
        </div>
        <ul class="error-list">
          <% errors.slice(0,5).forEach(error => { %>
            <li><%= error %></li>
          <% }) %>
        </ul>
      </div>
      <% } %>

      <div class="row">
        <div class="form-group">
          <label>First Name</label>
          <div class="input-box">
            <i class="fa-solid fa-user"></i>
            <input type="text" name="firstName"
              value="<%= oldInput.firstName || '' %>" placeholder="John" required />
          </div>
        </div>

        <div class="form-group">
          <label>Last Name</label>
          <div class="input-box">
            <i class="fa-solid fa-user"></i>
            <input type="text" name="lastName"
              value="<%= oldInput.lastName || '' %>" placeholder="Doe" required />
          </div>
        </div>
      </div>

      <div class="form-group">
        <label>Email</label>
        <div class="input-box">
          <i class="fa-solid fa-envelope"></i>
          <input type="email" name="email"
            value="<%= oldInput.email || '' %>" placeholder="email@example.com" required />
        </div>
      </div>

      <div class="form-group">
        <label>Password</label>
        <div class="input-box">
          <i class="fa-solid fa-lock"></i>
          <input type="password" name="password" placeholder="Enter your password"
              required />
        </div>
      </div>

      <div class="form-group">
        <label>Confirm Password</label>
        <div class="input-box">
          <i class="fa-solid fa-lock"></i>
          <input type="password" name="confirmPassword" placeholder="Confirm your password"
               required />
        </div>
      </div>

      <div class="radio-box">
        <strong>I want to register as:</strong><br />
        <label>
          <input type="radio" name="userType" value="guest"
            <%= oldInput.userType === 'guest' ? 'checked' : '' %> />
          Guest
        </label>
        <label>
          <input type="radio" name="userType" value="host"
            <%= oldInput.userType === 'host' ? 'checked' : '' %> />
          Host
        </label>
      </div>

      <div class="terms">
        <input type="checkbox" name="terms" />

        I agree to the <a href="#">terms and conditions</a>
      </div>

      <button class="btn">Register →</button>
    </form>

    <div class="login-link">
      Already have an account? <a href="/login">Log in</a>
    </div>

  </div>
</body>
</html>
