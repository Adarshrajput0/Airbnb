    <main class="pt-32 pb-20 flex justify-center bg-gradient-to-b from-[#fff1f2] via-white to-[#f7f7f7]">
  <div class="w-full max-w-2xl bg-white rounded-2xl shadow-xl p-10">

    <!-- Heading -->
    <div class="text-center mb-10">
      <h1 class="text-4xl font-semibold text-[#222] mb-3">
        <%= editing ? "Edit your home" : "Register your home" %>
      </h1>
      <p class="text-gray-500 text-sm">
        Share your beautiful space with travelers around the world.
      </p>
    </div>

    <!-- Form -->
    <form 
      action="/<%= editing ? "edithome" : "add-home" %>" 
      method="POST"
      class="space-y-6"
    >

      <input type="hidden" name="id" value="<%= editing ? home._id : '' %>" />

      <!-- House Name -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">
          House name
        </label>
        <input
          type="text"
          name="houseName"
          value="<%= editing ? home.houseName : '' %>"
          placeholder="e.g. Sea View Villa"
          required
          class="w-full px-4 py-3 border rounded-lg focus:ring-2 focus:ring-[#ff385c] focus:outline-none"
        />
      </div>

      <!-- Price & Rating -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">
            Price per night (₹)
          </label>
          <input
            type="number"
            name="price"
            value="<%= editing ? home.price : '' %>"
            placeholder="e.g. 2500"
            required
            class="w-full px-4 py-3 border rounded-lg focus:ring-2 focus:ring-[#ff385c] focus:outline-none"
          />
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">
            Rating (0 - 5)
          </label>
          <input
            type="number"
            step="0.1"
            max="5"
            name="rating"
            value="<%= editing ? home.rating : '' %>"
            placeholder="e.g. 4.5"
            required
            class="w-full px-4 py-3 border rounded-lg focus:ring-2 focus:ring-[#ff385c] focus:outline-none"
          />
        </div>
        <!-- Max Guests -->
<div>
  <label class="block text-sm font-medium text-gray-700 mb-1">
    Max Guests
  </label>
  <input
    type="number"
    name="maxguest"
    min="1"
    value="<%= editing ? home.maxGuests : '' %>"
    placeholder="e.g. 4"
    required
    class="w-full px-4 py-3 border rounded-lg focus:ring-2 focus:ring-[#ff385c] focus:outline-none"
  />
</div>

<!-- Property Type -->
<div>
  <label class="block text-sm font-medium text-gray-700 mb-1">
    Property Type
  </label>
  <select
    name="propertytype"
    required
    class="w-full px-4 py-3 border rounded-lg bg-white focus:ring-2 focus:ring-[#ff385c] focus:outline-none"
  >
    <option value="">Select property type</option>
    <option value="Apartment" <%= editing && home.propertyType === "Apartment" ? "selected" : "" %>>Apartment</option>
    <option value="Villa" <%= editing && home.propertyType === "Villa" ? "selected" : "" %>>Villa</option>
    <option value="Cottage" <%= editing && home.propertyType === "Cottage" ? "selected" : "" %>>Cottage</option>
    <option value="Farmhouse" <%= editing && home.propertyType === "Farmhouse" ? "selected" : "" %>>Farmhouse</option>
    <option value="Resort" <%= editing && home.propertyType === "Resort" ? "selected" : "" %>>Resort</option>
    <option value="Hostel" <%= editing && home.propertyType === "Hostel" ? "selected" : "" %>>Hostel</option>
  </select>
</div>



      </div>

      <!-- Location -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">
          Location
        </label>
        <input
          type="text"
          name="location"
          value="<%= editing ? home.location : '' %>"
          placeholder="e.g. Manali, Himachal Pradesh"
          required
          class="w-full px-4 py-3 border rounded-lg focus:ring-2 focus:ring-[#ff385c] focus:outline-none"
        />
      </div>

      <!-- Description -->
<div>
  <label class="block text-sm font-medium text-gray-700 mb-1">
    Description
  </label>
  <textarea
    name="description"
    rows="4"
    required
    placeholder="Describe your home, surroundings, and special features..."
    class="w-full px-4 py-3 border rounded-lg focus:ring-2 focus:ring-[#ff385c] focus:outline-none resize-none"
  ><%= editing ? home.description : '' %></textarea>
</div>


      <!-- Photo URL -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">
          Photo URL
        </label>
        <input
          type="text"
          name="photoUrl"
          value="<%= editing ? home.photoUrl : '' %>"
          placeholder="https://example.com/home.jpg"
          required
          class="w-full px-4 py-3 border rounded-lg focus:ring-2 focus:ring-[#ff385c] focus:outline-none"
        />
      </div>

      <!-- Submit Button -->
      <div class="pt-4">
        <button
          type="submit"
          class="w-full py-3 rounded-lg font-medium text-white bg-gradient-to-r from-[#ff385c] to-[#e31c5f] hover:shadow-lg hover:-translate-y-0.5 transition"
        >
          <%= editing ? "Update Home" : "Publish Home" %>
        </button>
      </div>

    </form>
  </div>
</main>

  </body>
</html>
