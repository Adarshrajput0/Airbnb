<form action="/favourites" method="POST" class="flex justify-center">
  <input type="hidden" name="id" value="<%= home._id %>" />

  <button
    type="submit"
    class="group flex items-center justify-center gap-2 w-full max-w-xs px-6 py-2.5 rounded-full bg-[#ff385c] text-white font-semibold text-sm shadow-md hover:bg-[#e31c5f] hover:shadow-lg hover:-translate-y-0.5 active:scale-[0.97] transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-[#ff385c]/40"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      fill="currentColor"
      viewBox="0 0 24 24"
      class="w-4 h-4 group-hover:scale-110 transition"
    >
      <path
        d="M12 21s-7.5-4.35-10-8.5C-0.5 8.5 2.5 4 7 4c2.1 0 3.6 1.2 5 2.8C13.4 5.2 14.9 4 17 4c4.5 0 7.5 4.5 5 8.5-2.5 4.15-10 8.5-10 8.5z"
      />
    </svg>

    Add to favourites
  </button>
</form>
