<header>
  
  <nav class="navbar">
    <div class="nav-container">
      
      
      <a href="/" class="logo">
        <svg viewBox="0 0 24 24" fill="currentColor" class="logo-icon">
          <path
            d="M12 2C8.1 2 5 5.1 5 9c0 5.2 7 13 7 13s7-7.8 7-13c0-3.9-3.1-7-7-7zm0 9.5c-1.4 0-2.5-1.1-2.5-2.5S10.6 6.5 12 6.5s2.5 1.1 2.5 2.5S13.4 11.5 12 11.5z"
          />
        </svg>
        <span>airbnb</span>
      </a>

    
      <div class="nav-right">

        <% if (isLoggedIn) { %>
          <% if (typeof user !== 'undefined' && user && user.userType === 'guest') { %>

  <a href="/homes" class="nav-link bold">
    <i class="fa-solid fa-house"></i> Homes
  </a>

  <a href="/favourites" class="nav-link bold">
    <i class="fa-solid fa-heart"></i> Favourites
  </a>

  <a href="/bookings" class="nav-link bold">
    <i class="fa-solid fa-calendar-check"></i> Bookings
  </a>
<% } else{%>
  <a href="/host-home-list" class="nav-link bold">
    <i class="fa-solid fa-user-tie"></i> Host
  </a>

  <a href="/add-home" class="add-home-btn">
    <i class="fa-solid fa-plus"></i> Add Home
  </a>
<% } %>
 

<% } else { %>


          <a href="/login" class="login-btn">Login</a>
          <a href="/signup" class="signup-btn">Signup</a>

        <% } %>

         <form action="/logout" method="POST">
    <button type="submit" class="logout-btn">
      <i class="fa-solid fa-right-from-bracket"></i> Logout
    </button>
  </form>

      </div>
    </div>
  </nav>
</header>


<style>
  .nav-btn {
    padding: 8px 16px;
    border-radius: 9999px;
    font-weight: 600;
    font-size: 14px;
    color: #374151;
    background: white;
    border: 1px solid rgba(0, 0, 0, 0.05);
    transition: all 0.25s ease;
  }

  .nav-btn:hover {
    background: #fff1f2;
    color: #ff385c;
    box-shadow: 0 6px 16px rgba(0, 0, 0, 0.08);
    transform: translateY(-1px);
  }

  /* NAVBAR */
.navbar {
  position: fixed;
  top: 0;
  width: 100%;
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(14px);
  border-bottom: 1px solid rgba(0, 0, 0, 0.06);
  box-shadow: 0 8px 25px rgba(0, 0, 0, 0.06);
  z-index: 999;
}

.nav-container {
  max-width: 1250px;
  margin: auto;
  padding: 18px 40px;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

/* LOGO */
.logo {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 30px;
  font-weight: 900;
  color: #ff385c;
  text-decoration: none;
}

.logo:hover{
  transform: translateY(-2px);
}

.logo-icon {
  width: 30px;
  height: 30px;
}

/* RIGHT SIDE */
.nav-right {
  display: flex;
  align-items: center;
  gap: 14px;
}

/* NAV LINKS */
.nav-link {
  padding: 8px 16px;
  border-radius: 30px;
  text-decoration: none;
  color: #444;
  font-weight: 600;
  font-size: 14px;
  transition: 0.25s ease;
}

.nav-link:hover {
  background: #fff1f2;
  color: #ff385c;
}

/* ADD HOME BUTTON */
.add-home-btn {
  background: #ff385c;
  color: white;
  padding: 10px 18px;
  border-radius: 30px;
  text-decoration: none;
  font-weight: 700;
  font-size: 14px;
  box-shadow: 0 10px 18px rgba(255, 56, 92, 0.25);
  transition: 0.25s;
}

.add-home-btn:hover {
  background: #e31c5f;
  transform: translateY(-2px);
}

/* LOGIN / SIGNUP */
.login-btn {
  text-decoration: none;
  background: #ff385c;
  color: white;
  padding: 10px 18px;
  border-radius: 30px;
  font-weight: 700;
  box-shadow: 0 10px 18px rgba(255, 56, 92, 0.25);
  transition: 0.25s;
}

.signup-btn {
  text-decoration: none;
  background: #ff385c;
  color: white;
  padding: 10px 18px;
  border-radius: 30px;
  font-weight: 700;
  box-shadow: 0 10px 18px rgba(255, 56, 92, 0.25);
  transition: 0.25s;
}

.signup-btn:hover {
  background: #e31c5f;
  transform: translateY(-2px);
}

/* LOGOUT */
.logout-btn {
  background: #ff385c;
  color: white;
  padding: 10px 18px;
  border-radius: 30px;
  border: none;
  font-weight: 700;
  cursor: pointer;
  transition: 0.25s;
}

.logout-btn:hover {
  background: #e31c5f;
  transform: translateY(-2px);
}
.bold {
  font-weight: 700;
  font-size: larger;
}

.nav-link i,
.add-home-btn i,
.logout-btn i {
  margin-right: 6px;
}



</style> 
