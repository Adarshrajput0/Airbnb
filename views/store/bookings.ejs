<link rel="stylesheet" href="/css/bookings.css">

<%- include('../partials/header') %>

<div class="booking-page">

  <div class="booking-container">

    <h1 class="booking-title">🏡 Your Bookings</h1>

    <div class="booking-grid">

      <% bookings.forEach(booking => { %>

        <div class="booking-card">

          <h3 class="booking-home">
            <%= booking.home.houseName %>
          </h3>

          <div class="booking-divider"></div>

          <div class="booking-details">

            <div class="booking-row">
              <span class="booking-label">Check-In</span>
              <span><%= booking.checkInDate.toDateString() %></span>
            </div>

            <div class="booking-row">
              <span class="booking-label">Check-Out</span>
              <span><%= booking.checkOutDate.toDateString() %></span>
            </div>

            <div class="booking-row">
              <span class="booking-label">Total Price</span>
              <span class="booking-price">
                ₹ <%= booking.totalPrice %>
              </span>
            </div>

          </div>

        </div>

      <% }) %>

    </div>

  </div>

</div>