
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/css/output.css" />

  <%- include('../partials/head') %>
  </head>

  <body
    class="min-h-screen bg-gradient-to-b from-[#fff1f2] via-white to-[#f7f7f7] font-sans"
  >
<!-- 
  <%- include('../partials/header') %> -->
  <%- include('../partials/header', { 
      isLoggedIn: isLoggedIn, 
      user: user 
}) %>

    <main class="pt-28 pb-16 bg-[#f7f7f7] min-h-screen">
  <div class="max-w-6xl mx-auto px-4">

    <!-- Hero Image -->
    <div class="relative rounded-3xl overflow-hidden shadow-xl">
      <img
        src="<%= home.photo %>"
        alt="<%= home.name %>"
        class="w-full h-[420px] object-cover"
      />

      <!-- <img
  src="<%= home.photo.startsWith('/') ? home.photo : '/' + home.photo.replace(/\\/g, '/') %>"
  alt="<%= home.houseName %>"
  class="w-full h-[420px] object-cover" -->


      
      <div class="absolute top-6 right-6 bg-black/70 text-white px-5 py-2 rounded-full text-sm font-semibold backdrop-blur">
        ₹ <%= home.price %> / night
      </div>
    </div>

    <!-- Content -->
    <div class="mt-10 grid grid-cols-1 lg:grid-cols-3 gap-10">

      <!-- Left Section -->
      <div class="lg:col-span-2 space-y-6">

        <h1 class="text-3xl md:text-4xl font-bold text-[#222]">
          <%= home.houseName %>
        </h1>

        <div class="flex items-center gap-4 text-gray-600">
          <span class="flex items-center gap-1 text-yellow-500 font-semibold">
            ⭐ <%= home.rating %>
          </span>
          <span>•</span>
          <span>📍 <%= home.location %></span>
        </div>

        <div class="h-px bg-gray-200"></div>

        <!-- Description -->
        <div class="space-y-3">
          <h2 class="text-xl font-semibold text-gray-900">
            About this place
          </h2>
          <p class="text-gray-600 leading-relaxed">
            Experience a comfortable and memorable stay at
            <strong><%= home.houseName %></strong>, located in the beautiful
            surroundings of <%= home.location %>. This property offers modern
            amenities, a peaceful environment, and a perfect getaway for
            couples, families, or solo travelers.
          </p>
        </div>

        <!-- Amenities -->
        <div class="space-y-3">
          <h2 class="text-xl font-semibold text-gray-900">
            Amenities
          </h2>
          <ul class="grid grid-cols-2 sm:grid-cols-3 gap-3 text-gray-600 text-sm">
            <li>✔ Free Wi-Fi</li>
            <li>✔ Kitchen</li>
            <li>✔ Air Conditioning</li>
            <li>✔ Parking</li>
            <li>✔ Power Backup</li>
          </ul>
        </div>

      </div>

      <!-- Right Booking Card -->
      <div class="lg:col-span-1">
        <div class="sticky top-32 bg-white rounded-2xl shadow-xl p-6 space-y-5">

          <div class="flex items-center justify-between">
            <span class="text-2xl font-bold text-gray-900">
              ₹ <%= home.price %>
            </span>
            <span class="text-gray-700 text-sm">per night</span>
          </div>

          <div class="flex items-center gap-1 text-yellow-500 font-semibold">
            ⭐ <%= home.rating %>
          </div>
          <div>

          <button
            class="w-full py-4 rounded-full
                   bg-[#FF385C] text-white font-semibold text-m
                   hover:bg-[#E31C5F] transition
                   shadow-md hover:shadow-m
                   active:scale-[0.97]"
          >
            Book Now
          </button>

          </div>
          <div>
            <%- include('../partials/favourite') %>
          </div>

          <p class="text-center text-sm text-gray-500">
            You won’t be charged yet
          </p>

        </div>
      </div>

    </div>
  </div>
</main>

  </body>
</html>
